################################################################################
# ParallelCluster v3 configuration for {{ cluster_name }}
# Generated by ParallelClusterMaker on {{ DEPLOYMENT_DATE }}
################################################################################

Region: {{ region }}

Image:
  Os: {{ pcluster_os }}
{% if custom_ami != 'NONE' %}
  CustomAmi: {{ custom_ami }}
{% endif %}

HeadNode:
  InstanceType: {{ headnode_instance_type }}
  DisableSimultaneousMultithreading: {{ 'true' if hyperthreading == 'false' else 'false' }}
  Networking:
    # WARNING: Subnet auto-discovered unless --headnode_subnet_id was provided.
    # Specify explicitly for production clusters.
    SubnetId: {{ subnet_id }}
  LocalStorage:
    RootVolume:
      VolumeType: {{ headnode_root_volume_type }}
      Size: {{ headnode_root_volume_size }}
      Encrypted: {{ ebs_encryption | lower }}
{% if headnode_root_volume_type in ('gp3', 'io1', 'io2') %}
      Iops: {{ headnode_root_volume_iops }}
{% endif %}
{% if headnode_root_volume_type == 'gp3' %}
      Throughput: {{ headnode_root_volume_throughput }}
{% endif %}
  Ssh:
    KeyName: {{ ec2_keypair }}
  Iam:
    InstanceRole: arn:aws:iam::{{ aws_account_id }}:role/{{ ec2_iam_role }}
  CustomActions:
    OnNodeStart:
      Script: s3://{{ s3_bucketname }}/{{ s3_script_path }}/{{ preinstall_s3_dest }}
{% if enable_monitoring == 'true' %}
    OnNodeConfigured:
      Sequence:
        - Script: s3://{{ s3_bucketname }}/{{ s3_script_path }}/{{ postinstall_s3_dest }}
        - Script: s3://{{ s3_bucketname }}/{{ s3_script_path }}/{{ monitoring_s3_dest }}
{% else %}
    OnNodeConfigured:
      Script: s3://{{ s3_bucketname }}/{{ s3_script_path }}/{{ postinstall_s3_dest }}
{% endif %}

Scheduling:
  Scheduler: {{ scheduler }}
  SlurmSettings:
    ScaledownIdletime: {{ scaledown_idletime }}
  SlurmQueues:
    - Name: compute
      CapacityType: {{ 'SPOT' if cluster_type == 'spot' else 'ONDEMAND' }}
      Networking:
        # WARNING: Subnets below were auto-discovered unless --compute_subnet_ids
        # was explicitly provided. Auto-discovery is non-deterministic when
        # multiple subnets exist per AZ. Always specify subnet IDs explicitly
        # for production clusters.
        SubnetIds:
{% for sid in (compute_subnet_ids if compute_subnet_ids is iterable and compute_subnet_ids is not string else compute_subnet_ids.split(',')) %}
          - {{ sid }}
{% endfor %}
{% if placement_group != 'NONE' %}
        PlacementGroup:
          Enabled: true
{% endif %}
      ComputeSettings:
        LocalStorage:
          RootVolume:
            VolumeType: {{ compute_root_volume_type }}
            Size: {{ compute_root_volume_size }}
            Encrypted: {{ ebs_encryption | lower }}
{% if compute_root_volume_type in ('gp3', 'io1', 'io2') %}
            Iops: {{ compute_root_volume_iops }}
{% endif %}
{% if compute_root_volume_type == 'gp3' %}
            Throughput: {{ compute_root_volume_throughput }}
{% endif %}
{% if enable_monitoring == 'true' %}
      CustomActions:
        OnNodeConfigured:
          Script: s3://{{ s3_bucketname }}/{{ s3_script_path }}/{{ monitoring_s3_dest }}
{% endif %}
      ComputeResources:
        - Name: compute-resource
          InstanceType: {{ compute_instance_type }}
          MinCount: {{ initial_queue_size if maintain_initial_size == 'true' else 0 }}
          MaxCount: {{ max_queue_size }}
          DisableSimultaneousMultithreading: {{ 'true' if hyperthreading == 'false' else 'false' }}
{% if enable_efa == 'true' %}
          Efa:
            Enabled: true
{% endif %}

SharedStorage:
  - MountDir: "{{ ebs_shared_dir }}"
    Name: ebs-shared
    StorageType: Ebs
    EbsSettings:
      VolumeType: {{ ebs_shared_volume_type }}
      Size: {{ ebs_shared_volume_size }}
      Encrypted: {{ ebs_encryption | lower }}
{% if ebs_shared_volume_type in ('gp3', 'io1', 'io2') %}
      Iops: {{ ebs_shared_volume_iops }}
{% endif %}
{% if ebs_shared_volume_type == 'gp3' %}
      Throughput: {{ ebs_shared_volume_throughput }}
{% endif %}
{% if enable_efs == 'true' %}

  - MountDir: /efs
    Name: efs-shared
    StorageType: Efs
    EfsSettings:
      Encrypted: {{ efs_encryption | lower }}
      PerformanceMode: {{ efs_performance_mode }}
      ThroughputMode: {{ efs_throughput_mode }}
{% endif %}
{% if enable_fsx == 'true' %}

  - MountDir: /fsx
    Name: fsx-lustre
    StorageType: FsxLustre
    FsxLustreSettings:
      StorageCapacity: {{ fsx_size }}
      WeeklyMaintenanceStartTime: "4:20:00"
{% if enable_fsx_hydration == 'true' %}
      ImportPath: s3://{{ fsx_s3_import_bucket }}/{{ fsx_s3_import_path }}
      ExportPath: s3://{{ fsx_s3_export_bucket }}/{{ fsx_s3_export_path }}
      ImportedFileChunkSize: {{ fsx_chunk_size }}
      AutoImportPolicy: NEW_CHANGED
{% endif %}
{% endif %}

Tags:
  - Key: ClusterID
    Value: "{{ cluster_name }}"
  - Key: ClusterStackType
    Value: ParallelCluster
  - Key: ClusterOSType
    Value: "{{ base_os }}"
  - Key: ClusterScheduler
    Value: "{{ scheduler }}"
  - Key: ClusterSerialNumber
    Value: "{{ cluster_serial_number }}"
  - Key: ClusterOwner
    Value: "{{ cluster_owner }}"
  - Key: ClusterOwnerEmail
    Value: "{{ cluster_owner_email }}"
  - Key: ClusterOwnerDepartment
    Value: "{{ cluster_owner_department }}"
{% if project_id != 'UNDEFINED' %}
  - Key: ProjectID
    Value: "{{ project_id }}"
{% endif %}
  - Key: ProdLevel
    Value: "{{ prod_level }}"
  - Key: DEPLOYMENT_DATE
    Value: "{{ DEPLOYMENT_DATE }}"

Monitoring:
  Dashboards:
    CloudWatch:
      Enabled: true
  Logs:
    CloudWatch:
      Enabled: true
