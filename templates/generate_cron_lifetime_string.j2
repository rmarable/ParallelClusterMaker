#!/bin/bash
set -euo pipefail
# Generated by ParallelClusterMaker — cluster lifetime scheduler
# cluster_lifetime format: D:HH:MM (days:hours:minutes)
CLUSTER_LIFETIME="{{ cluster_lifetime }}"
CLUSTER_NAME="{{ cluster_name }}"
KILL_SCRIPT="{{ cluster_data_dir }}/kill_pcluster.{{ cluster_name }}.sh"

# Parse D:HH:MM into total minutes
IFS=: read -r _days _hours _mins <<< "$CLUSTER_LIFETIME"
TOTAL_MINS=$(( (_days * 24 * 60) + (_hours * 60) + _mins ))

if [[ $TOTAL_MINS -gt 0 ]]; then
    if ! command -v at >/dev/null 2>&1; then
        echo "ERROR: 'at' command not found. Install 'at' (e.g. sudo apt-get install at) to enable cluster lifetime scheduling." >&2
        exit 1
    fi
    echo "Scheduling cluster ${CLUSTER_NAME} self-termination in ${TOTAL_MINS} minutes..."
    echo "bash \"${KILL_SCRIPT}\"" | at now + ${TOTAL_MINS} minutes
fi
