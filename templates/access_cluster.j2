#!/bin/bash
# Generated by ParallelClusterMaker
# SSH access wrapper for {{ cluster_name }}
set -euo pipefail
SSH_KEYPAIR="{{ ssh_keypair }}"
EC2_USER="{{ ec2_user }}"
RETRIEVE_SCRIPT="$(dirname "$0")/retrieve_ssh_key.{{ cluster_name }}.sh"

HEAD_NODE_IP="$(aws ec2 describe-instances \
    --region "{{ region }}" \
    --filters "Name=tag:parallelcluster:cluster-name,Values={{ cluster_name }}" \
              "Name=tag:parallelcluster:node-type,Values=HeadNode" \
              "Name=instance-state-name,Values=running" \
    --query 'Reservations[0].Instances[0].PublicIpAddress' \
    --output text 2>/dev/null || true)"

if [[ -z "$HEAD_NODE_IP" || "$HEAD_NODE_IP" == "None" ]]; then
    echo "ERROR: Could not resolve head node IP for {{ cluster_name }}. Is the cluster running?"
    exit 1
fi

if [[ ! -f "$SSH_KEYPAIR" ]]; then
    echo "Local key not found — retrieving from Secrets Manager..."
    bash "${RETRIEVE_SCRIPT}" --out "${SSH_KEYPAIR}"
fi

echo "Connecting to head node of {{ cluster_name }} at ${HEAD_NODE_IP}..."
exec ssh -i "${SSH_KEYPAIR}" -o StrictHostKeyChecking=accept-new "${EC2_USER}@${HEAD_NODE_IP}" "$@"
