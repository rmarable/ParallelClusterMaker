#!/bin/bash
set -euo pipefail
################################################################################
# Name:         monitoring-post-install-wrapper.{{ cluster_name }}.sh
# Generated by: ParallelClusterMaker on {{ DEPLOYMENT_DATE }}
# Purpose:      Install aws-parallelcluster-monitoring {{ monitoring_version }}
#               from S3 — no GitHub calls at node boot time.
################################################################################

source /etc/profile

MONITORING_VERSION="{{ monitoring_version }}"
TARBALL="aws-parallelcluster-monitoring-${MONITORING_VERSION}.tar.gz"
S3_URI="s3://{{ s3_bucketname }}/{{ s3_script_path }}/${TARBALL}"
INSTALL_DIR="/opt/aws-parallelcluster-monitoring"
LOG="/var/log/parallelcluster-monitoring-install.log"

exec > >(tee -a "$LOG") 2>&1

echo "[$(date)] Starting aws-parallelcluster-monitoring ${MONITORING_VERSION} install"

# Download tarball from S3 (instance role already has s3:GetObject on this bucket).
aws s3 cp "$S3_URI" "/tmp/${TARBALL}" --region {{ region }}

# Extract to install dir.
rm -rf "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR"
tar -xzf "/tmp/${TARBALL}" --strip-components=1 -C "$INSTALL_DIR"
rm -f "/tmp/${TARBALL}"

# Run the upstream installer with the pinned version tag.
bash "$INSTALL_DIR/post-install.sh" "$MONITORING_VERSION"

echo "[$(date)] aws-parallelcluster-monitoring install complete"
