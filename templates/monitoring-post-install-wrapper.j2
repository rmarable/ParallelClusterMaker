#!/bin/bash
set -euo pipefail
################################################################################
# Name:         monitoring-post-install-wrapper.{{ cluster_name }}.sh
# Generated by: ParallelClusterMaker on {{ DEPLOYMENT_DATE }}
# Purpose:      Install aws-parallelcluster-monitoring {{ monitoring_version }}
#               from S3 — no GitHub calls at node boot time.
#
# We bypass the upstream post-install.sh because it always re-downloads the
# tarball from GitHub. Instead we extract our S3-staged copy directly to
# MONITORING_HOME and invoke installer/install.sh, which is fully self-
# contained once the source tree is present on disk.
################################################################################

# /etc/profile on RHEL references unset variables; source it with -u suspended.
set +u
source /etc/profile
set -u

# Apache2 ships on Ubuntu PCluster head nodes and holds port 80, blocking the
# monitoring nginx container. Stop and disable it before the Docker stack starts.
if systemctl is-active --quiet apache2 2>/dev/null; then
    systemctl stop apache2
    systemctl disable apache2
fi

MONITORING_VERSION="{{ monitoring_version }}"
TARBALL="aws-parallelcluster-monitoring-${MONITORING_VERSION}.tar.gz"
S3_URI="s3://{{ s3_bucketname }}/{{ s3_script_path }}/${TARBALL}"
LOG="/var/log/parallelcluster-monitoring-install.log"

exec > >(tee -a "$LOG") 2>&1

echo "[$(date)] Starting aws-parallelcluster-monitoring ${MONITORING_VERSION} install"

# Derive MONITORING_HOME from cfnconfig (same logic as installer/platform/parallelcluster.sh).
# shellcheck disable=SC1091
source /etc/parallelcluster/cfnconfig
CLUSTER_USER="${cfn_cluster_user}"
MONITORING_HOME="/home/${CLUSTER_USER}/aws-parallelcluster-monitoring"

# Download tarball from S3 (instance role already has s3:GetObject on this bucket).
aws s3 cp "$S3_URI" "/tmp/${TARBALL}" --region {{ region }}

# Extract directly to MONITORING_HOME — no intermediate INSTALL_DIR needed.
rm -rf "$MONITORING_HOME"
mkdir -p "$MONITORING_HOME"
tar -xzf "/tmp/${TARBALL}" --strip-components=1 -C "$MONITORING_HOME"
rm -f "/tmp/${TARBALL}"

chown -R "${CLUSTER_USER}:${CLUSTER_USER}" "$MONITORING_HOME"

# Run the platform-aware installer directly (skipping post-install.sh's GitHub fetch).
set +e
bash -x "$MONITORING_HOME/installer/install.sh" 2>&1 | tee -a "$LOG"
rc=${PIPESTATUS[0]}
set -e

if [[ ${rc} -ne 0 ]]; then
    echo "=============================================================" >&2
    echo "monitoring install FAILED with exit ${rc}" >&2
    echo "last 80 lines of ${LOG}:" >&2
    echo "=============================================================" >&2
    tail -n 80 "$LOG" >&2 || true
fi

exit "${rc}"
