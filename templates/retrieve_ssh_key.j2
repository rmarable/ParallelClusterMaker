#!/usr/bin/env bash
# Generated by ParallelClusterMaker
# Retrieve the SSH private key for {{ cluster_name }} from AWS Secrets Manager.
#
# Usage: ./retrieve_ssh_key.{{ cluster_name }}.sh [--out /path/to/key.pem]
#
# Requires: aws CLI, jq, secretsmanager:GetSecretValue on the secret below.
# The operator's IAM user/role must have this permission — it is NOT granted
# via the cluster head node policy.
set -euo pipefail

SECRET_NAME="{{ ssh_secret_name }}"
REGION="{{ region }}"
DEFAULT_OUT="{{ ssh_keypair }}"
OUT="${1:-}"
if [[ "$OUT" == "--out" ]]; then
    OUT="${2:-}"
    if [[ -z "$OUT" ]]; then
        echo "ERROR: --out requires a path argument" >&2
        exit 1
    fi
fi
OUT="${OUT:-${DEFAULT_OUT}}"

aws secretsmanager get-secret-value \
    --secret-id "${SECRET_NAME}" \
    --region "${REGION}" \
    --query SecretString \
    --output text \
    > "${OUT}"
chmod 0600 "${OUT}"
echo "SSH private key written to: ${OUT}"
