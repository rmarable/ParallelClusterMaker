#!/bin/bash
# Generated by ParallelClusterMaker
# Grafana SSH tunnel for {{ cluster_name }}
set -euo pipefail

CLUSTER_NAME="{{ cluster_name }}"
REGION="{{ region }}"
SSH_KEYPAIR="{{ ssh_keypair }}"
EC2_USER="{{ ec2_user }}"
LOCAL_PORT="${1:-8443}"
PID_FILE="/tmp/grafana-tunnel-${CLUSTER_NAME}.pid"

case "${2:-start}" in
  stop)
    if [[ -f "$PID_FILE" ]]; then
      kill "$(cat "$PID_FILE")" 2>/dev/null && echo "Grafana tunnel for ${CLUSTER_NAME} stopped." || true
      rm -f "$PID_FILE"
    else
      echo "No tunnel PID file found for ${CLUSTER_NAME}."
    fi
    exit 0
    ;;
esac

HEAD_NODE_IP="$(aws ec2 describe-instances \
    --region "$REGION" \
    --filters "Name=tag:parallelcluster:cluster-name,Values=${CLUSTER_NAME}" \
              "Name=tag:parallelcluster:node-type,Values=HeadNode" \
              "Name=instance-state-name,Values=running" \
    --query 'Reservations[0].Instances[0].PublicIpAddress' \
    --output text 2>/dev/null || true)"

if [[ -z "$HEAD_NODE_IP" || "$HEAD_NODE_IP" == "None" ]]; then
  HEAD_NODE_IP="$(aws ec2 describe-instances \
      --region "$REGION" \
      --filters "Name=tag:parallelcluster:cluster-name,Values=${CLUSTER_NAME}" \
                "Name=tag:parallelcluster:node-type,Values=HeadNode" \
                "Name=instance-state-name,Values=running" \
      --query 'Reservations[0].Instances[0].PrivateIpAddress' \
      --output text 2>/dev/null || true)"
fi

if [[ -z "$HEAD_NODE_IP" || "$HEAD_NODE_IP" == "None" ]]; then
  echo "ERROR: Could not resolve head node IP for ${CLUSTER_NAME}. Is the cluster running?"
  exit 1
fi

if [[ -f "$SSH_KEYPAIR" ]]; then
  :
else
  RETRIEVE_SCRIPT="$(dirname "$0")/retrieve_ssh_key.${CLUSTER_NAME}.sh"
  echo "Local key not found — retrieving from Secrets Manager..."
  bash "${RETRIEVE_SCRIPT}" --out "${SSH_KEYPAIR}"
fi

ssh -i "$SSH_KEYPAIR" \
    -L "${LOCAL_PORT}:localhost:443" \
    -o StrictHostKeyChecking=accept-new \
    -o ExitOnForwardFailure=yes \
    -fN \
    "${EC2_USER}@${HEAD_NODE_IP}"

# Capture the PID of the backgrounded ssh process.
SSH_PID=$(pgrep -n -f "ssh.*${LOCAL_PORT}:localhost:443.*${HEAD_NODE_IP}" 2>/dev/null || true)
[[ -n "$SSH_PID" ]] && echo "$SSH_PID" > "$PID_FILE"

echo ""
echo "Grafana tunnel open for ${CLUSTER_NAME}."
echo "  URL:  https://localhost:${LOCAL_PORT}/grafana/"
echo "  Stop: $(basename "$0") ${LOCAL_PORT} stop"
echo ""
echo "Admin password:"
echo "  aws ssm get-parameter \\"
echo "    --region ${REGION} \\"
echo "    --name /parallelcluster/${CLUSTER_NAME}/grafana/admin-password \\"
echo "    --with-decryption --query Parameter.Value --output text"
echo ""
echo "Accept the self-signed certificate warning in your browser."
